{
  "domain": "eco",
  "ollama_host": "http://host.docker.internal:11434",
  "ollama_model": "qwen3.5:35b-a3b",
  "data_sources": {
    "eco": {
      "primary": "open-meteo",
      "apis": {
        "open-meteo": {
          "url": "https://air-quality-api.open-meteo.com/v1/air-quality",
          "key_required": false
        },
        "nasa-firms": {
          "url": "https://firms.modaps.eosdis.nasa.gov/api/area/csv/",
          "key_required": true,
          "key_env": "NASA_FIRMS_KEY"
        },
        "gfw": {
          "url": "https://data-api.globalforestwatch.org",
          "key_required": false
        }
      },
      "cache_dir": "data/cache/eco"
    },
    "human": {
      "primary": "provided",
      "apis": {},
      "cache_dir": "data/cache/human"
    },
    "culture": {
      "primary": "provided",
      "apis": {},
      "cache_dir": "data/cache/culture"
    }
  },
  "provided_data_dir": "data/provided",
  "thresholds": {
    "eco": {
      "aqi_critical": 200,
      "fire_count_alert": 100,
      "deforestation_rate": 0.5
    },
    "human": {
      "severity_critical": 0.8
    },
    "culture": {
      "impact_score": 0.7
    }
  },
  "pattern_levels": ["000", "111", "222", "333", "444", "555", "666"]
}
